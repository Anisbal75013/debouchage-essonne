---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import knowledgeMap from '../../../../data/knowledge_map.json';

export function getStaticPaths() {
  const paths = [];
  for (const [zoneKey, zone] of Object.entries(knowledgeMap.zones)) {
    for (const serviceKey of zone.primaryServices) {
      const service = knowledgeMap.services[serviceKey];
      if (!service) continue;
      const communes = knowledgeMap.communes
        .filter((c) => c.zone === zoneKey)
        .sort((a, b) => b.population - a.population);
      paths.push({
        params: { service: service.slug, zone: zone.slug },
        props: { service, zone: { ...zone, key: zoneKey }, communes },
      });
    }
  }
  return paths;
}

const { service, zone, communes } = Astro.props;
const site = knowledgeMap._meta.department.siteUrl;
const isUrgence = service.urgence === true;

const canonicalURL = `${site}/${service.slug}/${zone.slug}/`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: service.label, href: `/${service.slug}/` },
  { label: zone.label, href: `/${service.slug}/${zone.slug}/`, current: true },
];

// Groupes alphabétiques
const grouped = communes.reduce((acc, c) => {
  const letter = c.name[0].toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(c);
  return acc;
}, {} as Record<string, (typeof communes[number])[]>);

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site },
    { "@type": "ListItem", "position": 2, "name": service.label, "item": `${site}/${service.slug}/` },
    { "@type": "ListItem", "position": 3, "name": zone.label, "item": canonicalURL }
  ]
};

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${service.label} — ${zone.label}`,
  "numberOfItems": communes.length,
  "itemListElement": communes.slice(0, 20).map((c, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": `${service.label} à ${c.name}`,
    "url": `${site}/${service.slug}/${zone.slug}/${c.slug}/`
  }))
};
---

<Layout
  title={`${service.label} ${zone.label} (91) — ${communes.length} communes | Guide 91`}
  description={`${service.label} en ${zone.label} : retrouvez nos artisans agréés dans ${communes.length} communes de l'Essonne (91). Intervention rapide, devis gratuit.`}
  canonical={canonicalURL}
  schemas={[schemaBreadcrumb, schemaItemList]}
>
  <main class="max-w-5xl mx-auto px-4 py-8">

    <Breadcrumb items={breadcrumbs} />

    <!-- Hero zone -->
    <div class={`rounded-2xl p-8 mb-8 ${isUrgence ? 'bg-urgence-50 border-2 border-urgence-200' : 'bg-brand-50 border border-brand-100'}`}>
      <div class="flex flex-col md:flex-row items-start md:items-center gap-6">
        <div class="flex-1">
          {isUrgence && (
            <span class={`inline-block text-urgence-700 bg-urgence-100 font-bold text-xs px-3 py-1 rounded-full mb-3 uppercase tracking-wide`}>
              Urgence 24h/7j
            </span>
          )}
          <h1 class="text-3xl font-bold text-gray-900 mb-2">
            {service.label} — {zone.label}
          </h1>
          <p class="text-gray-600 text-lg mb-2">{zone.description}</p>
          <p class="text-sm text-brand-700 font-medium">
            {communes.length} communes couvertes · Artisans agréés · Devis gratuit
          </p>
        </div>
        {isUrgence && (
          <a
            href={`/track/appel/${service.slug}/${zone.slug}/hub/`}
            class="flex-shrink-0 bg-urgence-600 hover:bg-urgence-700 text-white font-bold px-6 py-4 rounded-xl transition-colors text-center shadow-md"
          >
            📞 Urgence maintenant<br/>
            <span class="text-sm font-normal opacity-90">Réponse immédiate</span>
          </a>
        )}
      </div>
    </div>

    <!-- Stats rapides -->
    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="text-center border border-gray-100 rounded-xl p-4">
        <div class="text-2xl font-bold text-brand-700">{communes.length}</div>
        <div class="text-xs text-gray-500 mt-1">Communes</div>
      </div>
      <div class="text-center border border-gray-100 rounded-xl p-4">
        <div class="text-2xl font-bold text-brand-700">{Math.round(communes.reduce((s,c) => s + c.population, 0) / 1000)}k</div>
        <div class="text-xs text-gray-500 mt-1">Habitants</div>
      </div>
      <div class="text-center border border-gray-100 rounded-xl p-4">
        <div class="text-2xl font-bold text-urgence-600">24h/7j</div>
        <div class="text-xs text-gray-500 mt-1">Disponibilité</div>
      </div>
    </div>

    <!-- Communes les plus demandées -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        {service.label} par commune en {zone.label}
      </h2>

      <!-- Top communes (haute priorité) -->
      {communes.filter(c => c.seo?.priorite === 'haute').length > 0 && (
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Grandes villes</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
            {communes
              .filter(c => c.seo?.priorite === 'haute')
              .map((c) => (
                <a
                  href={`/${service.slug}/${zone.slug}/${c.slug}/`}
                  class={`block p-4 rounded-xl border-2 transition-all hover:shadow-md ${
                    isUrgence
                      ? 'border-urgence-200 hover:border-urgence-400 bg-urgence-50'
                      : 'border-brand-200 hover:border-brand-400 bg-brand-50'
                  }`}
                >
                  <div class="font-semibold text-gray-900">{c.name}</div>
                  <div class="text-xs text-gray-500 mt-0.5">{c.cp[0]} · {(c.population/1000).toFixed(0)}k hab.</div>
                  <div class={`text-xs mt-1 font-medium ${isUrgence ? 'text-urgence-700' : 'text-brand-600'}`}>
                    {service.label} →
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      )}

      <!-- Autres communes (alphabétique) -->
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Toutes les communes</h3>
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          {Object.entries(grouped).sort().map(([letter, gComm]) => (
            <div class="border-b border-gray-100 last:border-0">
              <div class="bg-gray-50 px-4 py-2 text-xs font-bold text-gray-400 uppercase">{letter}</div>
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-0">
                {gComm.map((c) => (
                  <a
                    href={`/${service.slug}/${zone.slug}/${c.slug}/`}
                    class="px-4 py-2.5 text-sm text-gray-700 hover:text-brand-700 hover:bg-gray-50 border-b border-r border-gray-100 last:border-r-0 transition-colors"
                  >
                    {c.name}
                    <span class="text-xs text-gray-400 ml-1">{c.cp[0]}</span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class={`rounded-2xl p-8 text-center ${isUrgence ? 'bg-urgence-600' : 'bg-brand-900'} text-white`}>
      <h2 class="text-2xl font-bold mb-2">
        {service.label} en {zone.label} — Devis gratuit
      </h2>
      <p class="opacity-90 mb-6 text-sm">
        Artisans agréés, intervention rapide dans toute l'Essonne
      </p>
      <a
        href={`/track/appel/${service.slug}/${zone.slug}/hub/`}
        class={`inline-flex items-center gap-2 font-bold px-8 py-3 rounded-xl transition-colors text-lg ${isUrgence ? 'bg-white text-urgence-700 hover:bg-urgence-50' : 'bg-urgence-500 hover:bg-urgence-400 text-white'}`}
      >
        Appeler maintenant
      </a>
    </div>

  </main>
</Layout>
