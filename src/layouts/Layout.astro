---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schemas?: object[];
  /** Slug de tracking pour le bouton "Appeler" du header.
   *  Format : "{service}/{zone}/{commune}" ou "homepage/hero", "header", etc.
   *  Si omis → fallback "header" (clics non attribuables à une commune). */
  callTrackingSlug?: string;
}

const { title, description, canonical, schemas = [], callTrackingSlug } = Astro.props;
const callHref = `/track/appel/${callTrackingSlug ?? 'header'}/`;
const site = Astro.site?.href ?? 'https://www.debouchage-essonne.fr';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="fr_FR" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">

    <!-- ── Header ── -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-brand-900 font-bold text-base md:text-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
          </svg>
          <span>Guide Assainissement 91</span>
        </a>
        <a
          href={callHref}
          class="flex items-center gap-2 bg-urgence-600 hover:bg-urgence-700 text-white font-semibold px-3 md:px-5 py-2 rounded-lg transition-colors text-sm"
          aria-label="Appel urgence assainissement 24h/7j"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
          </svg>
          <span class="hidden sm:inline">Urgence</span> 24h/7j
        </a>
      </div>
    </header>

    <!-- ── Content ── -->
    <slot />

    <!-- ── Footer ── -->
    <footer class="bg-gray-900 text-gray-400 mt-16 py-12">
      <div class="max-w-5xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <div>
            <h3 class="text-white font-semibold mb-3">Débouchage Essonne</h3>
            <p class="text-sm leading-relaxed">
              Annuaire des professionnels agréés de l'assainissement en Essonne (91).
              Débouchage urgence, vidange fosse septique, curage réseau, inspection caméra.
            </p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">Nos services</h3>
            <ul class="text-sm space-y-2">
              <li><a href="/vidange-fosse-septique/" class="hover:text-white transition-colors">Vidange fosse septique</a></li>
              <li><a href="/debouchage-urgence/" class="hover:text-white transition-colors">Débouchage urgence</a></li>
              <li><a href="/curage-reseau/" class="hover:text-white transition-colors">Curage réseau</a></li>
              <li><a href="/inspection-camera/" class="hover:text-white transition-colors">Inspection caméra</a></li>
              <li><a href="/spanc-essonne/" class="hover:text-white transition-colors">SPANC Essonne</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">Zone d'intervention</h3>
            <ul class="text-sm space-y-2">
              <li><a href="/nord-essonne/" class="hover:text-white transition-colors">Nord Essonne (urbain)</a></li>
              <li><a href="/sud-essonne/" class="hover:text-white transition-colors">Sud Essonne (rural)</a></li>
              <li><a href="/annuaire/" class="hover:text-white transition-colors">Annuaire complet 91</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 pt-6 text-xs text-center space-y-1">
          <p>Débouchage Essonne &mdash; Annuaire des professionnels agréés de l'assainissement en Essonne (9