---
export interface BreadcrumbItem {
  name: string;
  url: string;
}
export interface Props {
  items: BreadcrumbItem[];
}
const { items } = Astro.props;
---

<nav aria-label="Fil d'Ariane" class="text-sm text-gray-500 mb-6">
  <ol class="flex flex-wrap items-center gap-1" itemscope itemtype="https://schema.org/BreadcrumbList">
    {items.map((item, index) => (
      <li
        class="flex items-center gap-1"
        itemprop="itemListElement"
        itemscope
        itemtype="https://schema.org/ListItem"
      >
        {index > 0 && <span aria-hidden="true" class="text-gray-300">/</span>}
        {index === items.length - 1 ? (
          <span class="text-gray-900 font-medium" aria-current="page" itemprop="name">
            {item.name}
          </span>
        ) : (
          <a
            href={item.url}
            class="hover:text-brand-600 transition-colors"
            itemprop="item"
          >
            <span itemprop="name">{item.name}</span>
          </a>
        )}
        <meta itemprop="position" content={String(index + 1)} />
      </li>
    ))}
  </ol>
</nav>
