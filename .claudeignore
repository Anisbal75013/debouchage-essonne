# ============================================================
# .claudeignore — Assainissement91
# Exclut du contexte Claude tout ce qui n'est pas du code source vivant
# ============================================================

# Build outputs
dist/
.astro/
.vercel/
.cloudflare/
out/

# Dépendances — jamais à scanner
node_modules/
.pnp/
.pnp.js

# Cache
.cache/
.turbo/
.parcel-cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Données volumineuses non-code (RÈGLE ABSOLUE DU PROJET)
COMPILATION_AVEC_DATES.txt
*.csv
*.sql
*.dump

# Fichiers générés automatiquement (ne pas éditer manuellement)
src/content/_generated/
public/sitemap*.xml
public/robots.txt

# Outils & config IDE
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Environnement
.env
.env.*
!.env.example
